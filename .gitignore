.DS_Store
.vim
*.log
*.tsbuildinfo
logs.txt
wikis
tests/staging
*.tgz
*.tsbuildinfo
.editorconfig
.gitattributes
coverage
.bun
dist
build
*.cast
*.gif
*.txt

# ignore all build artifacts
out
node_modules
bin
lib
dist

!bin/fish-lsp

# ignore all build scripts that are not needed for development,
# some of these might be added to tracked files in future, but
# for now these are mostly automation scripts that are not yet complete or are not needed for development
scripts/build-with-bun.sh
scripts/build-binary.ts
scripts/debug.fish
scripts/build-release.fish

# ignore all generated type declaration files, and temporary fish workspaces used for testing
release-assets
tsconfig.types.json
*.d.ts
temp-types
tests/workspaces/*.snapshot
temp-embedded-assets
tests/workspaces/example_test_src_1
tests/workspaces/tmp*
tests/workspaces/test_workspace*
tests/workspaces/diagnostic-workspace*
tests/workspaces/semantic-token-symbols-workspace*
tests/workspaces/semantic-tokens-simple-workspacetest_workspace_*
tests/workspaces/semantic-tokens-simple-workspace_*

# make sure to include important documentation files, but ignore the rest of the docs directory
!docs/CHANGELOG.md   
!docs/CONTRIBUTING.md
!docs/ROADMAP.md     
!docs/MAN_FILE.md    
docs/*
tsconfig.debug.json
dts-bundle.config.json
